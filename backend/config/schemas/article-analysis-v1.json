{
  "$id": "https://ai-tech-radar.local/schemas/article-analysis-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Tech Radar Article Analysis v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "technical_category", "tags", "summary_zh", "core_innovations", "differences_from_prior_work", "application_scenarios", "open_source_status", "credibility_score", "importance_score", "why_it_matters"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "technical_category": {"enum": ["foundation_models", "training", "inference", "agents", "multimodal", "computer_vision", "nlp", "speech_audio", "robotics", "data", "evaluation", "infrastructure", "safety", "other"]},
    "tags": {"type": "array", "minItems": 1, "maxItems": 10, "items": {"type": "string"}},
    "summary_zh": {"type": "string", "minLength": 20, "maxLength": 800},
    "core_innovations": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string"}},
    "differences_from_prior_work": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string"}},
    "application_scenarios": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string"}},
    "open_source_status": {"enum": ["open", "partial", "closed", "unknown"]},
    "credibility_score": {"type": "number", "minimum": 0, "maximum": 10},
    "importance_score": {"type": "number", "minimum": 0, "maximum": 10},
    "why_it_matters": {"type": "string", "minLength": 10, "maxLength": 500}
  }
}
